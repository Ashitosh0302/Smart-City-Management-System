<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Garbage Infrastructure | Government Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

        :root {
            --primary: #059669;
            --primary-light: #10b981;
            --primary-dark: #047857;
            --secondary: #34d399;
            --accent: #fbbf24;
            --accent-light: #fcd34d;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --light: #d1fae5;
            --light-green: #ecfdf5;
            --medium-green: #a7f3d0;
            --dark: #065f46;
            --text-dark: #064e3b;
            --text-light: #047857;
            --border: #a7f3d0;
            --shadow-sm: 0 4px 6px rgba(5, 150, 105, 0.1);
            --shadow-md: 0 6px 12px rgba(5, 150, 105, 0.15);
            --shadow-lg: 0 15px 25px rgba(5, 150, 105, 0.2);
            --transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0fdf4;
            color: var(--text-dark);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Animated Background - Nature/Environment Theme */
        .animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        /* Leaf pattern animation */
        .leaf-pattern {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(16, 185, 129, 0.03) 0%, transparent 20%),
                radial-gradient(circle at 90% 70%, rgba(5, 150, 105, 0.03) 0%, transparent 30%),
                radial-gradient(circle at 30% 80%, rgba(52, 211, 153, 0.03) 0%, transparent 25%),
                radial-gradient(circle at 70% 30%, rgba(16, 185, 129, 0.03) 0%, transparent 20%);
            background-size: 200px 200px;
            animation: leafFloat 30s infinite alternate;
        }

        @keyframes leafFloat {
            0% { transform: scale(1) rotate(0deg); }
            100% { transform: scale(1.1) rotate(2deg); }
        }

        /* Floating particles */
        .particle {
            position: absolute;
            background: rgba(16, 185, 129, 0.08);
            border-radius: 50%;
            filter: blur(8px);
            animation: particleDrift 20s infinite ease-in-out;
        }

        .particle1 {
            width: 300px;
            height: 300px;
            top: -100px;
            right: -100px;
            animation-duration: 25s;
        }

        .particle2 {
            width: 400px;
            height: 400px;
            bottom: -200px;
            left: -150px;
            background: rgba(52, 211, 153, 0.08);
            animation-duration: 30s;
            animation-delay: -5s;
        }

        .particle3 {
            width: 250px;
            height: 250px;
            top: 40%;
            left: 30%;
            background: rgba(5, 150, 105, 0.08);
            animation-duration: 22s;
            animation-delay: -3s;
        }

        @keyframes particleDrift {
            0% { transform: translate(0, 0) scale(1); opacity: 0.1; }
            50% { transform: translate(40px, -40px) scale(1.2); opacity: 0.2; }
            100% { transform: translate(-20px, 20px) scale(1); opacity: 0.1; }
        }

        /* Green wave lines */
        .wave-line {
            position: absolute;
            width: 100%;
            height: 3px;
            background: repeating-linear-gradient(90deg, 
                rgba(16, 185, 129, 0.1) 0px, 
                rgba(16, 185, 129, 0.1) 40px, 
                transparent 40px, 
                transparent 80px);
            animation: waveMove 15s linear infinite;
        }

        .wave1 {
            top: 15%;
            animation-duration: 18s;
        }

        .wave2 {
            top: 45%;
            animation-duration: 22s;
            animation-direction: reverse;
        }

        .wave3 {
            top: 75%;
            animation-duration: 20s;
        }

        @keyframes waveMove {
            0% { transform: translateX(-80px); }
            100% { transform: translateX(0); }
        }

        /* Grid pattern */
        .grid-pattern {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(5, 150, 105, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(5, 150, 105, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            animation: gridMove 25s linear infinite;
        }

        @keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(30px, 30px); }
        }

        /* Header */
        .govt-header {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            color: white;
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: var(--shadow-md);
            animation: slideDown 0.6s ease;
        }

        @keyframes slideDown {
            from { transform: translateY(-100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .govt-logo {
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.15);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--accent);
            animation: rotateSoft 8s infinite linear;
        }

        @keyframes rotateSoft {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .govt-title h1 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.2rem;
        }

        .govt-subtitle {
            font-size: 0.85rem;
            opacity: 0.9;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .logout-btn-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background: rgba(255,255,255,0.15);
            color: white;
            border: 2px solid rgba(255,255,255,0.25);
            padding: 0.75rem 1.5rem;
            border-radius: 30px;
            font-weight: 600;
            transition: var(--transition);
            text-decoration: none;
            backdrop-filter: blur(5px);
        }

        .logout-btn-header:hover {
            background: rgba(255,255,255,0.25);
            border-color: rgba(255,255,255,0.35);
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(4, 120, 87, 0.3);
        }

        /* Main Container */
        .main-container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 2rem;
            animation: fadeIn 0.8s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Welcome Card */
        .welcome-card {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border-radius: 24px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
            animation: cardFloat 6s infinite alternate;
        }

        @keyframes cardFloat {
            0% { transform: translateY(0); box-shadow: var(--shadow-lg); }
            100% { transform: translateY(-8px); box-shadow: 0 25px 30px rgba(4, 120, 87, 0.3); }
        }

        .welcome-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(251, 191, 36, 0.15) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .welcome-content {
            position: relative;
            z-index: 1;
        }

        .welcome-content h2 {
            font-size: 2rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .welcome-content h2 i {
            color: var(--accent);
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }

        .welcome-content p {
            opacity: 0.9;
            font-size: 1.1rem;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .stat-card {
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 20px;
            padding: 1.5rem;
            transition: var(--transition);
            animation: slideUp 0.6s ease;
            animation-fill-mode: both;
        }

        .stat-card:nth-child(1) { animation-delay: 0.1s; }
        .stat-card:nth-child(2) { animation-delay: 0.2s; }
        .stat-card:nth-child(3) { animation-delay: 0.3s; }
        .stat-card:nth-child(4) { animation-delay: 0.4s; }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .stat-card:hover {
            transform: translateY(-5px);
            background: rgba(255,255,255,0.2);
            border-color: var(--accent);
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.3rem;
            color: white;
        }

        .stat-label {
            color: rgba(255,255,255,0.9);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Filter Section */
        .filter-section {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: var(--shadow-md);
            margin-bottom: 2rem;
            border: 1px solid var(--border);
            animation: slideInRight 0.7s ease;
        }

        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .filter-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 1.2rem 2rem;
            border-radius: 20px 20px 0 0;
        }

        .filter-header h3 {
            font-size: 1.2rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .filter-body {
            padding: 2rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 0.5rem;
            display: block;
        }

        .form-select, .form-control {
            border: 2px solid var(--border);
            border-radius: 12px;
            padding: 0.75rem;
            width: 100%;
            font-size: 0.95rem;
            transition: var(--transition);
            background: white;
        }

        .form-select:focus, .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.1);
            outline: none;
        }

        .input-group {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 0.75rem 1.2rem;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-view {
            background: var(--primary);
            color: white;
        }

        .btn-view:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(4, 120, 87, 0.3);
        }

        .btn-cancel {
            background: var(--text-light);
            color: white;
        }

        .btn-cancel:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }

        /* Complaints Section */
        .complaints-section {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: var(--shadow-md);
            overflow: hidden;
            border: 1px solid var(--border);
            animation: slideInLeft 0.7s ease;
        }

        @keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .section-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 1.2rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .section-header h2 {
            font-size: 1.4rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 0;
        }

        .section-header h2 i {
            color: var(--accent);
            animation: bounce 2s infinite;
        }

        .section-header h2 small {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.9);
        }

        /* Table Styles */
        .table-container {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .complaints-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1200px;
        }

        .table-header th {
            background: var(--light-green);
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            color: var(--primary-dark);
            border-bottom: 2px solid var(--primary);
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .table-row {
            border-bottom: 1px solid var(--border);
            transition: var(--transition);
            animation: rowFade 0.5s ease;
        }

        @keyframes rowFade {
            from { opacity: 0; background: rgba(16, 185, 129, 0.05); }
            to { opacity: 1; background: transparent; }
        }

        .table-row:hover {
            background: var(--light-green);
            transform: scale(1.001);
            box-shadow: var(--shadow-sm);
        }

        .table-row td {
            padding: 1rem;
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .complaint-id {
            font-family: monospace;
            font-weight: 600;
            color: var(--primary);
        }

        .complaint-desc {
            max-width: 250px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            color: var(--text-dark);
        }

        .status-badge {
            display: inline-block;
            padding: 0.4rem 1rem;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 600;
            text-align: center;
            min-width: 90px;
            animation: badgePop 0.3s ease;
        }

        @keyframes badgePop {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        .status-pending {
            background: linear-gradient(135deg, var(--warning), #fbbf24);
            color: white;
        }

        .status-inprogress {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
        }

        .status-resolved {
            background: linear-gradient(135deg, var(--success), #34d399);
            color: white;
        }

        .garbage-type-badge {
            display: inline-block;
            padding: 0.3rem 0.8rem;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .type-household {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .type-construction {
            background: #fed7aa;
            color: #92400e;
            border: 1px solid #fdba74;
        }

        .type-industrial {
            background: #fbcfe8;
            color: #9d174d;
            border: 1px solid #f9a8d4;
        }

        .type-organic {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .type-mixed {
            background: #e0e7ff;
            color: #3730a3;
            border: 1px solid #c7d2fe;
        }

        .action-buttons {
            display: flex;
            gap: 0.4rem;
            flex-wrap: wrap;
        }

        .action-btn-small {
            padding: 0.4rem 0.8rem;
            border: none;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            background: var(--primary);
            color: white;
        }

        .action-btn-small:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(5, 150, 105, 0.3);
            background: var(--primary-dark);
        }

        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(6, 78, 59, 0.5);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            padding: 1rem;
            backdrop-filter: blur(5px);
            animation: fadeIn 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-content {
            background: white;
            border-radius: 24px;
            width: 100%;
            max-width: 700px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: var(--shadow-lg);
            animation: modalSlideUp 0.4s ease;
        }

        @keyframes modalSlideUp {
            from { opacity: 0; transform: translateY(50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .modal-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 24px 24px 0 0;
        }

        .modal-header h3 {
            font-size: 1.3rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            transition: var(--transition);
        }

        .modal-close:hover {
            transform: scale(1.1) rotate(90deg);
        }

        .modal-body {
            padding: 2rem;
        }

        .modal-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
        }

        .detail-section {
            background: var(--light-green);
            padding: 1.5rem;
            border-radius: 16px;
            margin-bottom: 1rem;
            border-left: 4px solid var(--primary);
            animation: slideRight 0.5s ease;
        }

        @keyframes slideRight {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .detail-section h4 {
            color: var(--primary-dark);
            margin-bottom: 1rem;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .detail-label {
            font-weight: 600;
            color: var(--text-dark);
            display: block;
            margin-bottom: 0.25rem;
            font-size: 0.9rem;
        }

        .detail-value {
            background: white;
            padding: 0.75rem;
            border-radius: 8px;
            border: 1px solid var(--border);
        }

        .btn-save {
            background: var(--success);
            color: white;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            transition: var(--transition);
        }

        .btn-save:hover {
            background: #047857;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(5, 150, 105, 0.3);
        }

        /* Toast Notification */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: white;
            padding: 1rem 1.5rem;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            display: flex;
            align-items: center;
            gap: 1rem;
            transform: translateX(150%);
            transition: transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            z-index: 3000;
            border-left: 4px solid var(--success);
        }

        .toast.show {
            transform: translateX(0);
        }

        .toast i {
            font-size: 1.2rem;
        }

        .toast-success i { color: var(--success); }
        .toast-error i { color: var(--danger); }
        .toast-warning i { color: var(--warning); }

        /* Pagination */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem 2rem;
            border-top: 1px solid var(--border);
            flex-wrap: wrap;
        }

        .page-btn {
            padding: 0.5rem 1rem;
            border: 2px solid var(--border);
            background: white;
            border-radius: 30px;
            cursor: pointer;
            transition: var(--transition);
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-btn:hover:not(:disabled) {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .page-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .page-info {
            color: var(--text-light);
            font-weight: 500;
        }

        /* Responsive Design */
        @media (max-width: 1024px) {
            .main-container { padding: 0 1rem; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .header-container { 
                flex-direction: column; 
                text-align: center; 
            }
            .logo-section { 
                flex-direction: column; 
            }
            .govt-title h1 { 
                font-size: 1.2rem; 
            }
            
            .welcome-content h2 { 
                font-size: 1.5rem; 
                flex-wrap: wrap;
                justify-content: center;
            }
            .welcome-content p { 
                font-size: 1rem; 
                text-align: center;
            }
            
            .stats-grid { 
                grid-template-columns: 1fr; 
            }
            
            .section-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
            
            .filter-body .row { 
                gap: 1rem; 
            }
            
            .input-group { 
                flex-direction: column;
            }
            
            .input-group .action-btn {
                width: 100%;
                justify-content: center;
            }
            
            .action-buttons { 
                justify-content: flex-start;
            }
            
            /* Mobile table view */
            .complaints-table thead { 
                display: none; 
            }
            
            .complaints-table tr {
                display: block;
                margin-bottom: 1rem;
                border: 1px solid var(--border);
                border-radius: 12px;
                padding: 1rem;
                background: white;
            }
            
            .complaints-table td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0.75rem;
                border-bottom: 1px dashed var(--border);
            }
            
            .complaints-table td:last-child { 
                border-bottom: none; 
            }
            
            .complaints-table td::before {
                content: attr(data-label);
                font-weight: 600;
                color: var(--primary);
                width: 120px;
                flex-shrink: 0;
            }
            
            .complaint-desc { 
                max-width: 100%; 
                white-space: normal;
            }
        }

        @media (max-width: 480px) {
            .main-container { 
                padding: 0.5rem; 
            }
            .welcome-card { 
                padding: 1.5rem; 
            }
            .stat-value { 
                font-size: 2rem; 
            }
            .modal-content { 
                margin: 0.5rem; 
            }
            .detail-grid { 
                grid-template-columns: 1fr; 
            }
            .filter-body { 
                padding: 1rem; 
            }
            .pagination { 
                gap: 0.5rem;
            }
            .page-btn { 
                font-size: 0.8rem; 
                padding: 0.4rem 0.8rem;
            }
        }

        /* Scrollbar */
        .table-container::-webkit-scrollbar {
            height: 6px;
        }

        .table-container::-webkit-scrollbar-track {
            background: var(--light-green);
        }

        .table-container::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 6px;
        }

        a { text-decoration: none; }
    </style>
</head>
<body>
    <!-- Animated Background - Nature/Environment Theme -->
    <div class="animated-bg">
        <div class="leaf-pattern"></div>
        <div class="grid-pattern"></div>
        <div class="particle particle1"></div>
        <div class="particle particle2"></div>
        <div class="particle particle3"></div>
        <div class="wave-line wave1"></div>
        <div class="wave-line wave2"></div>
        <div class="wave-line wave3"></div>
    </div>

    <!-- Header -->
    <header class="govt-header">
        <div class="header-container">
            <div class="logo-section">
                <div class="govt-logo">
                    <i class="fas fa-trash-alt"></i>
                </div>
                <div class="govt-title">
                    <h1>Garbage Infrastructure</h1>
                    <p class="govt-subtitle">Complaint Management Dashboard</p>
                </div>
            </div>
            <div class="header-actions">
                <a href="/login/logout" class="logout-btn-header">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <div class="main-container">
        <!-- Welcome Card -->
        <div class="welcome-card">
            <div class="welcome-content">
                <h2>
                    <i class="fas fa-trash-alt"></i>
                    Garbage Complaints Management
                </h2>
                <p>Monitor and manage garbage collection and disposal complaints from citizens across the city</p>
            </div>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value" id="totalComplaints">0</div>
                    <div class="stat-label">Total</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="pendingComplaints">0</div>
                    <div class="stat-label">Pending</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="inProgressComplaints">0</div>
                    <div class="stat-label">In Progress</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="resolvedComplaints">0</div>
                    <div class="stat-label">Resolved</div>
                </div>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="filter-section">
            <div class="filter-header">
                <h3><i class="fas fa-filter"></i> Filter Garbage Complaints</h3>
            </div>
            <div class="filter-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="statusFilter">
                            <option value="all">All Status</option>
                            <option value="Pending">Pending</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Resolved">Resolved</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Garbage Type</label>
                        <select class="form-select" id="garbageTypeFilter">
                            <option value="all">All Types</option>
                            <option value="household">Household Waste</option>
                            <option value="construction">Construction Waste</option>
                            <option value="industrial">Industrial Waste</option>
                            <option value="organic">Organic Waste</option>
                            <option value="mixed">Mixed Waste</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Date Range</label>
                        <select class="form-select" id="dateFilter">
                            <option value="all">All Time</option>
                            <option value="today">Today</option>
                            <option value="week">This Week</option>
                            <option value="month">This Month</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Search</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="searchInput" placeholder="Search...">
                            <button class="action-btn btn-view" onclick="filterComplaints()">
                                <i class="fas fa-search"></i>
                            </button>
                            <button class="action-btn btn-cancel" onclick="clearFilters()">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Complaints Table -->
        <section class="complaints-section">
            <div class="section-header">
                <h2>
                    <i class="fas fa-list"></i>
                    Garbage Complaints List
                    <small id="tableCount">(0)</small>
                </h2>
                <button class="action-btn btn-view" onclick="loadComplaints()">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>

            <div class="table-container">
                <table class="complaints-table">
                    <thead class="table-header">
                        <tr>
                            <th>ID</th>
                            <th>Description</th>
                            <th>Type</th>
                            <th>Qty</th>
                            <th>Citizen</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="complaintsTableBody">
                        <tr>
                            <td colspan="8" style="text-align: center; padding: 3rem;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-3">Loading garbage complaints...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination">
                <button class="page-btn" id="prevBtn" onclick="changePage(-1)" disabled>
                    <i class="fas fa-chevron-left"></i> Prev
                </button>
                <span class="page-info" id="pageInfo">Page 1 of 1</span>
                <button class="page-btn" id="nextBtn" onclick="changePage(1)" disabled>
                    Next <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </section>
    </div>

    <!-- View Modal -->
    <div class="modal-overlay" id="viewModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-trash-alt"></i> Garbage Complaint Details</h3>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body" id="complaintDetails"></div>
            <div class="modal-footer">
                <button class="action-btn btn-cancel" onclick="closeModal()">Close</button>
            </div>
        </div>
    </div>

    <!-- Update Modal -->
    <div class="modal-overlay" id="updateModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-edit"></i> Update Complaint</h3>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body" id="updateForm"></div>
            <div class="modal-footer">
                <button class="action-btn btn-cancel" onclick="closeModal()">Cancel</button>
                <button class="btn-save" onclick="saveUpdate()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast">
        <i class="fas fa-check-circle"></i>
        <div>
            <div class="fw-bold" id="toastTitle">Success</div>
            <div class="text-muted" id="toastMessage">Operation completed</div>
        </div>
    </div>

    <script>
        // Global variables
        let allComplaints = [];
        let filteredComplaints = [];
        let currentPage = 1;
        let currentComplaintId = '';
        const itemsPerPage = 10;

        // Load complaints on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadComplaints();
            
            document.getElementById('statusFilter').addEventListener('change', filterComplaints);
            document.getElementById('garbageTypeFilter').addEventListener('change', filterComplaints);
            document.getElementById('dateFilter').addEventListener('change', filterComplaints);
            document.getElementById('searchInput').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') filterComplaints();
            });
        });

        // Mock data
        function getMockGarbageComplaints() {
            return [
                {
                    _id: "1",
                    complainId: "GC-001",
                    description: "Construction waste piled up for 3 days causing blockage in the area",
                    garbageType: "construction",
                    quantity: "Large",
                    fullName: "Ashitsh Shirsath",
                    status: "Pending",
                    createdAt: "2026-01-27T19:57:40.644Z",
                    phone: "7276691717",
                    address: { street: "123 Main Street", area: "Downtown", city: "CityZen" },
                    issueType: "irregular",
                    duration: "1"
                },
                {
                    _id: "2",
                    complainId: "GC-002",
                    description: "Garbage not collected for 2 days, bins are overflowing",
                    garbageType: "household",
                    quantity: "Medium",
                    fullName: "Priya Sharma",
                    status: "In Progress",
                    createdAt: "2026-01-26T14:30:00Z",
                    phone: "9876543210",
                    address: { street: "456 Oak Avenue", area: "Green Park", city: "CityZen" },
                    issueType: "not_collected",
                    duration: "2"
                },
                {
                    _id: "3",
                    complainId: "GC-003",
                    description: "Industrial waste overflowing from bins, hazardous materials visible",
                    garbageType: "industrial",
                    quantity: "Extra Large",
                    fullName: "Raj Patel",
                    status: "Resolved",
                    createdAt: "2026-01-25T11:45:00Z",
                    phone: "8765432109",
                    address: { street: "789 Pine Road", area: "Industrial Zone", city: "CityZen" },
                    issueType: "overflowing",
                    duration: "5"
                },
                {
                    _id: "4",
                    complainId: "GC-004",
                    description: "Organic waste creating foul smell, attracting pests",
                    garbageType: "organic",
                    quantity: "Small",
                    fullName: "Sneha Verma",
                    status: "Pending",
                    createdAt: "2026-01-28T09:15:00Z",
                    phone: "7654321098",
                    address: { street: "321 Elm Street", area: "Residential Area", city: "CityZen" },
                    issueType: "smell",
                    duration: "1"
                }
            ];
        }

        function _capWords(str) {
            return String(str || '')
                .split(' ')
                .filter(Boolean)
                .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
                .join(' ');
        }

        function mapGarbageComplaint(raw) {
            return {
                ...raw,
                complainId: raw.complainId || raw.complaintId || raw._id,
                fullName: raw.fullName || raw.citizenName || 'Citizen',
                status: _capWords(raw.status || 'Pending'),
                createdAt: raw.createdAt || new Date().toISOString(),
                address: raw.address || {}
            };
        }

        async function loadComplaints() {
            try {
                document.getElementById('complaintsTableBody').innerHTML = `
                    <tr><td colspan="8" style="text-align: center; padding: 3rem;"><div class="spinner-border text-primary"></div><p class="mt-3">Loading...</p></td></tr>
                `;

                const basePath = window.location.pathname.replace(/\/$/, '');
                const response = await fetch(basePath, {
                    credentials: 'include',
                    headers: { 'Accept': 'application/json' }
                });

                if (!response.ok) throw new Error(`Server responded with ${response.status}`);

                const data = await response.json();
                const complaints = (data.complaints || []).map(mapGarbageComplaint);

                allComplaints = complaints;
                filteredComplaints = [...allComplaints];

                updateStats();
                renderTable();
                showToast('Data loaded successfully', 'success');
            } catch (error) {
                console.error(error);
                showToast('Failed to load complaints (showing demo data)', 'error');
                allComplaints = getMockGarbageComplaints();
                filteredComplaints = [...allComplaints];
                updateStats();
                renderTable();
            }
        }

        function updateStats() {
            const total = allComplaints.length;
            const pending = allComplaints.filter(c => c.status === 'Pending').length;
            const inProgress = allComplaints.filter(c => c.status === 'In Progress').length;
            const resolved = allComplaints.filter(c => c.status === 'Resolved').length;

            document.getElementById('totalComplaints').textContent = total;
            document.getElementById('pendingComplaints').textContent = pending;
            document.getElementById('inProgressComplaints').textContent = inProgress;
            document.getElementById('resolvedComplaints').textContent = resolved;
        }

        function filterComplaints() {
            const status = document.getElementById('statusFilter').value;
            const garbageType = document.getElementById('garbageTypeFilter').value;
            const dateFilter = document.getElementById('dateFilter').value;
            const search = document.getElementById('searchInput').value.toLowerCase();

            filteredComplaints = allComplaints.filter(c => {
                if (status !== 'all' && c.status !== status) return false;
                if (garbageType !== 'all' && c.garbageType !== garbageType) return false;
                
                if (dateFilter !== 'all') {
                    const now = new Date();
                    const complaintDate = new Date(c.createdAt);
                    if (dateFilter === 'today' && complaintDate.toDateString() !== now.toDateString()) return false;
                    if (dateFilter === 'week') {
                        const weekAgo = new Date(now - 7*24*60*60*1000);
                        if (complaintDate < weekAgo) return false;
                    }
                    if (dateFilter === 'month') {
                        const monthAgo = new Date(now.getFullYear(), now.getMonth()-1, now.getDate());
                        if (complaintDate < monthAgo) return false;
                    }
                }
                
                if (search) {
                    return c.description?.toLowerCase().includes(search) ||
                           c.complainId?.toLowerCase().includes(search) ||
                           c.fullName?.toLowerCase().includes(search);
                }
                return true;
            });

            currentPage = 1;
            renderTable();
        }

        function clearFilters() {
            document.getElementById('statusFilter').value = 'all';
            document.getElementById('garbageTypeFilter').value = 'all';
            document.getElementById('dateFilter').value = 'all';
            document.getElementById('searchInput').value = '';
            filteredComplaints = [...allComplaints];
            currentPage = 1;
            renderTable();
        }

        function formatGarbageType(type) {
            const types = {
                'household': 'Household',
                'construction': 'Construction',
                'industrial': 'Industrial',
                'organic': 'Organic',
                'mixed': 'Mixed'
            };
            return types[type] || type;
        }

        function getGarbageTypeClass(type) {
            const classes = {
                'household': 'type-household',
                'construction': 'type-construction',
                'industrial': 'type-industrial',
                'organic': 'type-organic',
                'mixed': 'type-mixed'
            };
            return classes[type] || 'type-household';
        }

        function renderTable() {
            const tbody = document.getElementById('complaintsTableBody');
            const totalPages = Math.ceil(filteredComplaints.length / itemsPerPage);
            const start = (currentPage - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const pageComplaints = filteredComplaints.slice(start, end);

            document.getElementById('tableCount').textContent = `(${filteredComplaints.length})`;
            document.getElementById('pageInfo').textContent = `Page ${currentPage} of ${totalPages || 1}`;
            document.getElementById('prevBtn').disabled = currentPage === 1;
            document.getElementById('nextBtn').disabled = currentPage === totalPages || totalPages === 0;

            if (pageComplaints.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; padding: 3rem;">
                    <i class="fas fa-trash-alt fa-3x mb-3" style="color: #94a3b8;"></i>
                    <p>No complaints found</p></td></tr>`;
                return;
            }

            tbody.innerHTML = pageComplaints.map(c => {
                const date = new Date(c.createdAt).toLocaleDateString('en-US', {
                    month: 'short', day: 'numeric', year: 'numeric'
                });

                return `
                    <tr class="table-row">
                        <td data-label="ID" class="complaint-id">${c.complainId}</td>
                        <td data-label="Description" class="complaint-desc" title="${c.description}">${c.description.substring(0, 50)}...</td>
                        <td data-label="Type"><span class="garbage-type-badge ${getGarbageTypeClass(c.garbageType)}">${formatGarbageType(c.garbageType)}</span></td>
                        <td data-label="Qty">${c.quantity}</td>
                        <td data-label="Citizen">${c.fullName}</td>
                        <td data-label="Date">${date}</td>
                        <td data-label="Status"><span class="status-badge status-${c.status.toLowerCase().replace(' ', '')}">${c.status}</span></td>
                        <td data-label="Actions">
                            <div class="action-buttons">
                                <button class="action-btn-small" onclick="viewComplaint('${c._id}')"><i class="fas fa-eye"></i> View</button>
                                <button class="action-btn-small" onclick="updateComplaint('${c._id}')"><i class="fas fa-edit"></i> Edit</button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function changePage(direction) {
            const totalPages = Math.ceil(filteredComplaints.length / itemsPerPage);
            const newPage = currentPage + direction;
            if (newPage >= 1 && newPage <= totalPages) {
                currentPage = newPage;
                renderTable();
            }
        }

        function viewComplaint(id) {
            const complaint = allComplaints.find(c => c._id === id);
            if (!complaint) return;

            const details = `
                <div class="detail-section">
                    <h4><i class="fas fa-info-circle"></i> Complaint Details</h4>
                    <div class="detail-grid">
                        <div><span class="detail-label">ID:</span> ${complaint.complainId}</div>
                        <div><span class="detail-label">Status:</span> <span class="status-badge status-${complaint.status.toLowerCase().replace(' ', '')}">${complaint.status}</span></div>
                        <div><span class="detail-label">Type:</span> ${formatGarbageType(complaint.garbageType)}</div>
                        <div><span class="detail-label">Quantity:</span> ${complaint.quantity}</div>
                    </div>
                </div>
                <div class="detail-section">
                    <h4><i class="fas fa-user"></i> Citizen Info</h4>
                    <div class="detail-grid">
                        <div><span class="detail-label">Name:</span> ${complaint.fullName}</div>
                        <div><span class="detail-label">Phone:</span> ${complaint.phone}</div>
                    </div>
                </div>
                <div class="detail-section">
                    <h4><i class="fas fa-map-marker"></i> Location</h4>
                    <div class="detail-grid">
                        <div><span class="detail-label">Street:</span> ${complaint.address?.street}</div>
                        <div><span class="detail-label">Area:</span> ${complaint.address?.area}</div>
                        <div><span class="detail-label">City:</span> ${complaint.address?.city}</div>
                    </div>
                </div>
                <div class="detail-section">
                    <h4><i class="fas fa-align-left"></i> Description</h4>
                    <p>${complaint.description}</p>
                </div>
            `;

            document.getElementById('complaintDetails').innerHTML = details;
            document.getElementById('viewModal').classList.add('active');
        }

        function updateComplaint(id) {
            const complaint = allComplaints.find(c => c._id === id);
            if (!complaint) return;

            currentComplaintId = id;

            const form = `
                <div class="form-group mb-3">
                    <label class="form-label">Complaint ID</label>
                    <input type="text" class="form-control" value="${complaint.complainId}" readonly>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Citizen Name</label>
                    <input type="text" class="form-control" value="${complaint.fullName}" readonly>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" id="statusSelect">
                        <option value="Pending" ${complaint.status === 'Pending' ? 'selected' : ''}>Pending</option>
                        <option value="In Progress" ${complaint.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                        <option value="Resolved" ${complaint.status === 'Resolved' ? 'selected' : ''}>Resolved</option>
                    </select>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Government Notes</label>
                    <textarea class="form-control" id="govtNotes" rows="3" placeholder="Add resolution notes...">${complaint.govtNotes || ''}</textarea>
                </div>
            `;

            document.getElementById('updateForm').innerHTML = form;
            document.getElementById('updateModal').classList.add('active');
        }

        async function saveUpdate() {
            try {
                const status = document.getElementById('statusSelect').value;
                const notes = document.getElementById('govtNotes').value;

                const basePath = window.location.pathname.replace(/\/$/, '');

                const isMock = String(currentComplaintId).length < 10;
                if (isMock) {
                    const index = allComplaints.findIndex(c => c._id === currentComplaintId);
                    if (index !== -1) {
                        allComplaints[index].status = status;
                        allComplaints[index].govtNotes = notes;
                    }
                } else {
                    const response = await fetch(`${basePath}/${currentComplaintId}`, {
                        method: 'PUT',
                        credentials: 'include',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ status, govtNotes: notes })
                    });

                    const data = await response.json();
                    if (!response.ok || !data.success) {
                        throw new Error(data.message || `Update failed (${response.status})`);
                    }

                    const updated = mapGarbageComplaint(data.complaint);
                    const index = allComplaints.findIndex(c => String(c._id) === String(currentComplaintId));
                    if (index !== -1) allComplaints[index] = updated;
                }

                filteredComplaints = [...allComplaints];
                updateStats();
                renderTable();
                closeModal();
                showToast('Updated successfully', 'success');
            } catch (error) {
                console.error(error);
                showToast(error.message || 'Failed to update complaint', 'error');
            }
        }

        function closeModal() {
            document.getElementById('viewModal').classList.remove('active');
            document.getElementById('updateModal').classList.remove('active');
        }

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            toast.querySelector('#toastMessage').textContent = message;
            toast.style.borderLeftColor = type === 'success' ? '#10b981' : type === 'error' ? '#ef4444' : '#f59e0b';
            toast.querySelector('i').style.color = type === 'success' ? '#10b981' : type === 'error' ? '#ef4444' : '#f59e0b';
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('modal-overlay')) closeModal();
        });
    </script>
</body>
</html>
