<!DOCTYPE html>
<html>
<head>
    <title>CityZen - Government Registration</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #b6ddfd, #92c1f0, #84b8f3);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Arial, sans-serif;
            padding: 20px;
        }

        .card {
            border-radius: 18px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 20px 40px rgba(30, 60, 114, 0.18);
            border: none;
        }

        .registration-header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 8px;
        }

        .logo-circle-container {
            position: relative;
            width: 60px;
            height: 60px;
            margin: 0;
            animation: scaleIn 0.8s ease-out 0.1s both;
        }

        .logo-circle {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: #ffffff;
            padding: 4px;
            box-shadow: 0 10px 22px rgba(30, 60, 114, 0.18);
            border: 3px solid #ffffff;
        }

        .logo-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

        @keyframes scaleIn {
            0% {
                opacity: 0;
                transform: scale(0.85);
            }
            100% {
                opacity: 1;
                transform: scale(1);
            }
        }

        .registration-title {
            font-size: 1.4rem;
            font-weight: 600;
            color: #1e3c72;
        }

        .registration-subtitle {
            font-size: 0.9rem;
            color: #2a5298;
        }

        .card-header {
            background: linear-gradient(135deg, #f0f7ff, #e6f0fa);
            border-bottom: 1px solid rgba(30, 60, 114, 0.12);
            border-radius: 18px 18px 0 0;
            padding: 20px 22px 12px;
        }

        .card-body {
            padding: 20px 22px 22px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            border: none;
            border-radius: 12px;
            padding: 10px 0;
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(30, 60, 114, 0.25);
            transition: all 0.25s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(30, 60, 114, 0.3);
        }
    </style>
</head>

<body>

<div class="card shadow p-2">
    <div class="card-header">
        <div class="registration-header">
            <div class="logo-circle-container">
                <div class="logo-circle">
                    <img src="/public/CityZen logo.jpeg" alt="CityZen Logo">
                </div>
            </div>
            <div>
                <h3 class="registration-title mb-1">Government Registration</h3>
                <p class="registration-subtitle mb-0">Secure access for city departments</p>
            </div>
        </div>
    </div>

    <div class="card-body">
    <form action="/government/government_register" method="POST">

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input 
                type="email" 
                name="email" 
                class="form-control" 
                required
            >
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <input 
                type="password" 
                name="password" 
                class="form-control" 
                required
            >
        </div>

        <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <input 
                type="password" 
                name="confirm_password" 
                class="form-control" 
                required
            >
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-2">
            Register
        </button>
    </form>

    <div class="text-center mt-3">
        <a href="/government/login" class="text-decoration-none">
            Already registered? Login
        </a>
    </div>
    </div>
</div>

</body>
</html>
