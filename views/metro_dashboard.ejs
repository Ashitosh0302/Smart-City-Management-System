<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Metro Management | CityZen Transport</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        :root {
            --off-white: #f8f8f6;
            --off-white-card: #fafaf8;
            --off-white-border: #e8e8e4;
            --text-dark: #333;
            --text-muted: #666;
            
            /* Beautiful skin and orange color palette */
            --skin-light: #fbe9e7;
            --skin-soft: #ffd9c0;
            --peach: #ffccbc;
            --coral: #ffab91;
            --orange-soft: #ffb174;
            --orange-medium: #ff9f4b;
            --orange-deep: #ff8a3c;
            --terracotta: #e67e5a;
            --brown-warm: #8b5a2b;
            --cream: #fff3e0;
        }
        
        body { 
            background: linear-gradient(145deg, #fbe9e7 0%, #ffd9c0 35%, #ffccbc 70%, #ffab91 100%);
            min-height: 100vh; 
            color: var(--text-dark); 
            font-family: 'Segoe UI', sans-serif;
            position: relative;
            background-size: 200% 200%;
            animation: warmFlow 15s ease infinite;
        }

        @keyframes warmFlow {
            0% { background-position: 0% 0%; }
            25% { background-position: 50% 25%; }
            50% { background-position: 100% 50%; }
            75% { background-position: 50% 75%; }
            100% { background-position: 0% 100%; }
        }
        
        .dash-header { 
            background: rgba(255, 248, 245, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            padding: 1rem 2rem; 
            border-bottom: 1px solid rgba(255, 171, 145, 0.3); 
            box-shadow: 0 8px 32px rgba(230, 126, 90, 0.15);
            animation: slideDown 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            z-index: 10;
        }

        @keyframes slideDown {
            0% { opacity: 0; transform: translateY(-30px) scaleY(0.98); backdrop-filter: blur(0px); }
            100% { opacity: 1; transform: translateY(0) scaleY(1); backdrop-filter: blur(12px); }
        }
        
        .dash-header a { 
            color: #b45f2b; 
            text-decoration: none;
            transition: all 0.3s ease;
            padding: 0.5rem 1.2rem;
            border-radius: 30px;
            background: rgba(255, 239, 227, 0.5);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255, 171, 145, 0.3);
        }
        
        .dash-header a:hover { 
            color: #8b4513; 
            background: rgba(255, 239, 227, 0.8);
            border-color: rgba(230, 126, 90, 0.5);
            transform: translateX(5px) scale(1.05);
            box-shadow: 0 4px 15px rgba(230, 126, 90, 0.2);
        }
        
        .dash-header strong {
            background: linear-gradient(135deg, #b45f2b, #e67e5a, #ff8a3c, #ff9f4b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: warmShimmer 5s ease infinite;
            background-size: 300% 300%;
            font-size: 1.2rem;
            font-weight: 700;
        }

        @keyframes warmShimmer {
            0% { background-position: 0% 50%; }
            25% { background-position: 50% 25%; }
            50% { background-position: 100% 50%; }
            75% { background-position: 50% 75%; }
            100% { background-position: 0% 50%; }
        }
        
        .card-gray { 
            background: rgba(255, 250, 245, 0.9);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 171, 145, 0.2); 
            border-radius: 28px; 
            box-shadow: 0 20px 40px -15px rgba(230, 126, 90, 0.2);
            animation: fadeInUp 0.9s cubic-bezier(0.2, 0.9, 0.3, 1.2);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .card-gray::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 150px;
            background: linear-gradient(135deg, rgba(255, 171, 145, 0.15), rgba(255, 159, 75, 0.15), rgba(230, 126, 90, 0.15));
            border-radius: 28px 28px 50% 50%;
            pointer-events: none;
        }

        .card-gray:hover {
            box-shadow: 0 30px 50px -15px rgba(230, 126, 90, 0.3);
            transform: translateY(-8px);
            background: rgba(255, 250, 245, 0.95);
        }

        @keyframes fadeInUp {
            0% { opacity: 0; transform: translateY(40px) scale(0.95); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        .card-gray h5 {
            background: linear-gradient(135deg, #b45f2b, #e67e5a, #ff8a3c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
            font-size: 1.4rem;
            position: relative;
            display: inline-block;
        }

        .card-gray h5::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 50px;
            height: 3px;
            background: linear-gradient(90deg, #ffab91, #ff9f4b, #ff8a3c);
            border-radius: 3px;
            animation: lineExpand 1s ease-out forwards;
        }

        @keyframes lineExpand {
            0% { width: 0; opacity: 0; }
            100% { width: 50px; opacity: 1; }
        }
        
        .table-gray { 
            color: #5a3e2b;
            border-collapse: separate;
            border-spacing: 0 12px;
            margin-top: -8px;
        }
        
        .table-gray thead { 
            background: linear-gradient(135deg, rgba(255, 171, 145, 0.2), rgba(255, 159, 75, 0.2), rgba(230, 126, 90, 0.2));
            color: #b45f2b; 
            border-radius: 20px;
            backdrop-filter: blur(5px);
        }

        .table-gray thead th {
            border: none;
            padding: 1.2rem 1rem;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 0.5px;
            color: #8b5a2b;
        }

        .table-gray thead th:first-child {
            border-radius: 20px 0 0 20px;
            padding-left: 1.5rem;
        }

        .table-gray thead th:last-child {
            border-radius: 0 20px 20px 0;
            padding-right: 1.5rem;
        }
        
        .table-gray tbody tr { 
            border: none;
            background: rgba(255, 245, 235, 0.7);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            transition: all 0.4s cubic-bezier(0.2, 0.9, 0.3, 1.2);
            animation: slideInRow 0.6s cubic-bezier(0.2, 0.9, 0.3, 1.2) forwards;
            opacity: 0;
            border-radius: 20px;
            box-shadow: 0 4px 10px rgba(255, 171, 145, 0.15);
            position: relative;
            overflow: hidden;
        }

        .table-gray tbody tr::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 171, 145, 0.1), rgba(255, 159, 75, 0.1));
            transform: translateX(-100%);
            transition: transform 0.6s ease;
            pointer-events: none;
        }

        .table-gray tbody tr:hover::before {
            transform: translateX(0);
        }

        .table-gray tbody tr:nth-child(1) { animation-delay: 0.1s; }
        .table-gray tbody tr:nth-child(2) { animation-delay: 0.2s; }
        .table-gray tbody tr:nth-child(3) { animation-delay: 0.3s; }
        .table-gray tbody tr:nth-child(4) { animation-delay: 0.4s; }
        .table-gray tbody tr:nth-child(5) { animation-delay: 0.5s; }

        @keyframes slideInRow {
            0% { opacity: 0; transform: translateX(-30px) scale(0.95); }
            100% { opacity: 1; transform: translateX(0) scale(1); }
        }

        .table-gray tbody tr:hover {
            background: rgba(255, 245, 235, 0.9);
            transform: translateY(-5px) scale(1.01);
            box-shadow: 0 15px 30px -10px rgba(230, 126, 90, 0.25);
        }

        .table-gray td {
            border: none;
            padding: 1.2rem 1rem;
            vertical-align: middle;
        }

        .table-gray td:first-child {
            border-radius: 20px 0 0 20px;
            padding-left: 1.5rem;
        }

        .table-gray td:last-child {
            border-radius: 0 20px 20px 0;
            padding-right: 1.5rem;
        }
        
        .table-gray input, .table-gray select { 
            background: rgba(255, 255, 255, 0.9);
            border: 2px solid #ffe4d5;
            border-radius: 16px;
            color: #5a3e2b;
            transition: all 0.3s ease;
            padding: 0.7rem 1rem;
            font-weight: 500;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .table-gray input:focus, .table-gray select:focus {
            border-color: #ff9f4b;
            box-shadow: 0 0 0 4px rgba(255, 159, 75, 0.15);
            outline: none;
            transform: scale(1.02);
            background: white;
        }

        .table-gray input:hover, .table-gray select:hover {
            border-color: #ff8a3c;
            background: white;
        }
        
        .btn-save { 
            background: linear-gradient(135deg, #ff9f4b, #ff8a3c, #e67e5a);
            border: none; 
            color: white;
            padding: 0.6rem 1.5rem;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.3px;
            transition: all 0.4s ease;
            box-shadow: 0 8px 20px -8px rgba(255, 159, 75, 0.5);
            position: relative;
            overflow: hidden;
            background-size: 200% 200%;
            animation: buttonWarm 4s ease infinite;
        }

        @keyframes buttonWarm {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .btn-save::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: left 0.6s ease;
        }
        
        .btn-save:hover { 
            transform: translateY(-4px) scale(1.05);
            box-shadow: 0 15px 30px -8px rgba(255, 159, 75, 0.7);
            filter: brightness(1.05);
        }

        .btn-save:hover::before {
            left: 100%;
        }

        .btn-save:active {
            transform: translateY(0) scale(1);
        }
        
        .btn-del { 
            background: linear-gradient(135deg, #e67e5a, #d46b4a, #c45a3a);
            border: none; 
            color: white;
            padding: 0.6rem 1.5rem;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.3px;
            transition: all 0.4s ease;
            box-shadow: 0 8px 20px -8px rgba(230, 126, 90, 0.5);
            position: relative;
            overflow: hidden;
            background-size: 200% 200%;
            animation: buttonWarm 4s ease infinite reverse;
        }

        .btn-del::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: left 0.6s ease;
        }
        
        .btn-del:hover { 
            transform: translateY(-4px) scale(1.05);
            box-shadow: 0 15px 30px -8px rgba(230, 126, 90, 0.7);
            filter: brightness(1.05);
        }

        .btn-del:hover::before {
            left: 100%;
        }

        .btn-del:active {
            transform: translateY(0) scale(1);
        }

        /* Loading animation */
        .text-muted {
            animation: warmPulse 1.8s ease-in-out infinite;
            background: linear-gradient(135deg, #b45f2b, #e67e5a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 1.1rem;
            font-weight: 600;
        }

        @keyframes warmPulse {
            0%, 100% { opacity: 0.6; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.02); }
        }

        /* Container animation */
        .container {
            animation: containerFade 1.2s ease-out;
        }

        @keyframes containerFade {
            0% { opacity: 0; }
            100% { opacity: 1; }
        }

        /* Button focus effects */
        .btn-save:focus, .btn-del:focus {
            outline: none;
            animation: focusRing 1.5s ease infinite;
        }

        @keyframes focusRing {
            0% { box-shadow: 0 0 0 0 rgba(255, 159, 75, 0.5); }
            70% { box-shadow: 0 0 0 8px rgba(255, 159, 75, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 159, 75, 0); }
        }

        /* Floating particles effect */
        .dash-header::after {
            content: '● ● ●';
            position: absolute;
            bottom: 5px;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255, 171, 145, 0.3);
            font-size: 0.8rem;
            letter-spacing: 8px;
            animation: floatWarm 4s ease-in-out infinite;
            white-space: nowrap;
        }

        @keyframes floatWarm {
            0%, 100% { opacity: 0.2; transform: translateX(-50%) scale(1); }
            50% { opacity: 0.5; transform: translateX(-50%) scale(1.1); }
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: linear-gradient(135deg, #fbe9e7, #ffd9c0);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #ff9f4b, #ff8a3c);
            border-radius: 5px;
            border: 2px solid #fbe9e7;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #ff8a3c, #e67e5a);
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .dash-header {
                padding: 1rem;
            }
            
            .dash-header strong {
                font-size: 1rem;
            }
            
            .card-gray {
                padding: 1.5rem !important;
            }
            
            .btn-save, .btn-del {
                padding: 0.5rem 1rem;
                font-size: 0.8rem;
            }

            .table-gray thead th {
                font-size: 0.9rem;
                padding: 1rem 0.5rem;
            }

            .table-gray td {
                padding: 1rem 0.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="dash-header d-flex justify-content-between align-items-center">
        <div>
            <a href="/transport"><i class="fas fa-arrow-left me-2"></i>Back</a>
            <span class="mx-3 text-muted">|</span>
            <strong><i class="fas fa-train-subway me-2"></i>Metro Management Dashboard</strong>
        </div>
        <a href="/login/logout"><i class="fas fa-sign-out-alt"></i></a>
    </div>

    <div class="container mt-4">
        <div class="card card-gray p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0">Metro Timetable</h5>
                <button class="btn btn-save" id="btnAdd"><i class="fas fa-plus me-1"></i>Create Metro Route</button>
            </div>

            <table class="table table-gray table-bordered">
                <thead>
                    <tr>
                        <th>Line No</th>
                        <th>Trains</th>
                        <th>Start Time</th>
                        <th>End Time</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="routesBody">
                    <tr><td colspan="5" class="text-center text-muted">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        const API = '/transport/api/metro/routes';
        async function load() {
            try {
                const r = await fetch(API, { credentials: 'include' });
                const d = await r.json();
                const routes = d.routes || [];
                const tbody = document.getElementById('routesBody');
                if (routes.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">No routes. Click "Create Metro Route" to add.</td></tr>';
                    return;
                }
                tbody.innerHTML = routes.map(r => `
                    <tr data-id="${r._id}">
                        <td><input class="form-control form-control-sm lineNo" value="${r.lineNo || ''}"></td>
                        <td><input type="number" class="form-control form-control-sm trains" value="${r.trains ?? ''}"></td>
                        <td><input type="time" class="form-control form-control-sm startTime" value="${r.startTime || ''}"></td>
                        <td><input type="time" class="form-control form-control-sm endTime" value="${r.endTime || ''}"></td>
                        <td>
                            <button class="btn btn-save btn-sm me-1 btnUpdate">Save</button>
                            <button class="btn btn-del btn-sm btnDelete">Delete</button>
                        </td>
                    </tr>
                `).join('');
                bindRowEvents();
            } catch (e) {
                document.getElementById('routesBody').innerHTML = '<tr><td colspan="5" class="text-center text-danger">Error loading data</td></tr>';
            }
        }
        function bindRowEvents() {
            document.querySelectorAll('.btnUpdate').forEach(btn => {
                btn.onclick = async () => {
                    const row = btn.closest('tr');
                    const id = row.dataset.id;
                    const payload = {
                        lineNo: row.querySelector('.lineNo').value,
                        trains: parseInt(row.querySelector('.trains').value) || 0,
                        startTime: row.querySelector('.startTime').value,
                        endTime: row.querySelector('.endTime').value
                    };
                    const r = await fetch(API + '/' + id, { method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                    if (r.ok) load();
                };
            });
            document.querySelectorAll('.btnDelete').forEach(btn => {
                btn.onclick = async () => {
                    if (!confirm('Delete this route?')) return;
                    const id = btn.closest('tr').dataset.id;
                    const r = await fetch(API + '/' + id, { method: 'DELETE', credentials: 'include' });
                    if (r.ok) load();
                };
            });
        }
        document.getElementById('btnAdd').onclick = async () => {
            const lineNo = prompt('Line No (e.g. Metro-Line-3):');
            if (!lineNo) return;
            const payload = { lineNo, trains: 0, startTime: '', endTime: '' };
            const r = await fetch(API, { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            if (r.ok) load();
        };
        load();
    </script>
</body>
</html>
